direction: down

# Tighten the plugin defaults for this single-cluster diagram.
vars: {
  d2-config: {
    data: {
      graphviz: |
        {"global_attrs": {"nodesep": "0.6", "ranksep": "0.8"}}
      |
    }
  }
}

title: |md
  # Door Access Controller
| {
  near: top-center
  shape: text
  style.font-size: 20
}

start: _ {shape: circle; style.fill: "#333"}
locked: LOCKED {style.fill: "#ddeeff"}
auth: AUTHENTICATING {style.fill: "#FFD700"; style.bold: true}
unlocked: UNLOCKED {style.fill: "#90EE90"; style.bold: true}
open: OPEN {style.fill: "#d4edda"}
closed: CLOSED {style.fill: "#ddeeff"}
denied: AUTH DENIED {style.fill: "#FFB6C1"}
lockout: LOCKOUT {style.fill: "#FFB6C1"}
fault: SENSOR FAULT {style.fill: "#FFB6C1"}

start -> locked
locked -> auth: badge presented
auth -> unlocked: valid credential
unlocked -> open: door pulled
open -> closed: door pushed
closed -> locked: auto-lock timeout
auth -> denied: invalid credential
denied -> locked: retry timeout
denied -> lockout: 3 failed attempts
lockout -> locked: admin reset
open -> fault: sensor lost
fault -> closed: sensor recovered
unlocked -> locked: cancel
